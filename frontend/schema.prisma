generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolGlobal {
  JUGADOR
  ENTRENADOR
  ADMIN_EQUIP
  ADMIN_WEB
  ARBITRE
  SUPERADMIN
}

enum RolEquip {
  JUGADOR
  ENTRENADOR
  ADMIN_EQUIP
}

enum Status {
  PENDENT
  COMPLETAT
  CANCELAT
}

enum TipusPista {
  COBERTA
  DESCOBERTA
}

enum Posicio {
  DRETA
  REVES
}

model Usuari {
  id            Int             @id @default(autoincrement())
  nom           String
  email         String          @unique
  contrasenya   String
  telefon       String?
  dataNaixement DateTime?
  nivell        String?
  avatar        String?
  dni           String?         @unique
  rols          UsuariRol[]
  equips        EquipUsuari[]
  notificacions Notificacio[]
  puntuacions   Puntuacio[]
  compres       Compra[]
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  isActive      Boolean         @default(true)
  PartitJugador PartitJugador[]
  Acta          Acta[]
  Alineacio     Alineacio[]
}

model UsuariRol {
  id       Int       @id @default(autoincrement())
  usuari   Usuari    @relation(fields: [usuariId], references: [id])
  usuariId Int
  rol      RolGlobal
  isActive Boolean   @default(true)
}

model Club {
  id           Int          @id @default(autoincrement())
  nom          String
  equips       Equip[]
  instalacions Instalacio[]
  isActive     Boolean      @default(true)
}

model Equip {
  id               Int             @id @default(autoincrement())
  nom              String
  categoria        String
  club             Club            @relation(fields: [clubId], references: [id])
  clubId           Int
  usuaris          EquipUsuari[]
  partitsLocals    Partit[]        @relation("local_partits")
  partitsVisitants Partit[]        @relation("visitante_partits")
  lligues          Lliga[]
  classificacions  Classificacio[]
  isActive         Boolean         @default(true)
  PartitJugador    PartitJugador[]
  Alineacio        Alineacio[]
}

model EquipUsuari {
  id       Int      @id @default(autoincrement())
  equip    Equip    @relation(fields: [equipId], references: [id])
  equipId  Int
  usuari   Usuari   @relation(fields: [usuariId], references: [id])
  usuariId Int
  rolEquip RolEquip
  isActive Boolean  @default(true)
}

model Lliga {
  id              Int             @id @default(autoincrement())
  nom             String
  categoria       String
  jornades        Jornada[]
  equips          Equip[]
  classificacions Classificacio[]
  isActive        Boolean         @default(true)
}

model Classificacio {
  id              Int   @id @default(autoincrement())
  lliga           Lliga @relation(fields: [lligaId], references: [id])
  lligaId         Int
  equip           Equip @relation(fields: [equipId], references: [id])
  equipId         Int
  partitsJugats   Int   @default(0)
  partitsGuanyats Int   @default(0)
  partitsPerduts  Int   @default(0)
  partitsEmpatats Int   @default(0)
  setsGuanyats    Int   @default(0)
  setsPerduts     Int   @default(0)
  jocsGuanyats    Int   @default(0)
  jocsPerduts     Int   @default(0)
  punts           Int   @default(0)

  @@unique([lligaId, equipId])
}

model Jornada {
  id       Int      @id @default(autoincrement())
  nom      String
  data     DateTime
  lliga    Lliga    @relation(fields: [lligaId], references: [id])
  lligaId  Int
  partits  Partit[]
  status   Status   @default(PENDENT)
  isActive Boolean  @default(true)
}

model Instalacio {
  id       Int     @id @default(autoincrement())
  nom      String
  adreca   String
  telefon  String?
  club     Club?   @relation(fields: [clubId], references: [id])
  clubId   Int?
  pistes   Pista[]
  isActive Boolean @default(true)
}

model Pista {
  id           Int        @id @default(autoincrement())
  nom          String
  tipus        TipusPista
  instalacio   Instalacio @relation(fields: [instalacioId], references: [id])
  instalacioId Int
  partits      Partit[]
  isActive     Boolean    @default(true)
}

model Partit {
  id             Int             @id @default(autoincrement())
  jornada        Jornada         @relation(fields: [jornadaId], references: [id])
  jornadaId      Int
  local          Equip           @relation("local_partits", fields: [localId], references: [id])
  localId        Int
  visitant       Equip           @relation("visitante_partits", fields: [visitantId], references: [id])
  visitantId     Int
  dataHora       DateTime
  pista          Pista?          @relation(fields: [pistaId], references: [id])
  pistaId        Int?
  partitJugadors PartitJugador[]
  acta           Acta?
  status         Status          @default(PENDENT)
  isActive       Boolean         @default(true)
  Puntuacio      Puntuacio[]
  Alineacio      Alineacio[]
  SetPartit      SetPartit[]
}

model SetPartit {
  id                 Int     @id @default(autoincrement())
  partit             Partit  @relation(fields: [partitId], references: [id])
  partitId           Int
  numeroSet          Int
  jocsLocal          Int
  jocsVisit          Int
  tiebreak           Boolean @default(false)
  puntsLocalTiebreak Int?
  puntsVisitTiebreak Int?

  @@unique([partitId, numeroSet])
}

model Alineacio {
  id        Int      @id @default(autoincrement())
  partit    Partit   @relation(fields: [partitId], references: [id])
  partitId  Int
  jugador   Usuari   @relation(fields: [jugadorId], references: [id])
  jugadorId Int
  equip     Equip    @relation(fields: [equipId], references: [id])
  equipId   Int
  posicio   Posicio
  isActive  Boolean  @default(true)
  creada_at DateTime @default(now())
}

model PartitJugador {
  id        Int     @id @default(autoincrement())
  partit    Partit  @relation(fields: [partitId], references: [id])
  partitId  Int
  jugador   Usuari  @relation(fields: [jugadorId], references: [id])
  jugadorId Int
  equip     Equip   @relation(fields: [equipId], references: [id])
  equipId   Int
  punts     Int     @default(0)
  isActive  Boolean @default(true)
}

model Acta {
  id            Int       @id @default(autoincrement())
  partit        Partit    @relation(fields: [partitId], references: [id])
  partitId      Int       @unique
  arbitre       Usuari    @relation(fields: [arbitreId], references: [id])
  arbitreId     Int
  observacions  String?
  incidencies   String?
  resultat      String?
  validada      Boolean   @default(false)
  dataValidacio DateTime?
  created_at    DateTime  @default(now())
  isActive      Boolean   @default(true)
}

model Puntuacio {
  id        Int     @id @default(autoincrement())
  partit    Partit  @relation(fields: [partitId], references: [id])
  partitId  Int
  jugador   Usuari  @relation(fields: [jugadorId], references: [id])
  jugadorId Int
  punts     Int     @default(0)
  isActive  Boolean @default(true)
}

model Notificacio {
  id         Int      @id @default(autoincrement())
  usuari     Usuari   @relation(fields: [usuariId], references: [id])
  usuariId   Int
  titol      String
  missatge   String
  llegit     Boolean  @default(false)
  created_at DateTime @default(now())
  isActive   Boolean  @default(true)
}

model Merch {
  id         Int      @id @default(autoincrement())
  nom        String
  marca      String
  descripcio String?
  preu       Float
  stock      Int
  imatges    String[]
  talles     String[]
  compres    Compra[]
  isActive   Boolean  @default(true)
}

model Compra {
  id              Int       @id @default(autoincrement())
  usuari          Usuari    @relation(fields: [usuariId], references: [id])
  usuariId        Int
  merch           Merch     @relation(fields: [merchId], references: [id])
  merchId         Int
  quantitat       Int
  talla           String?
  total           Float
  adrecaEnviament String?
  dataEnviament   DateTime?
  numeroSeguiment String?
  created_at      DateTime  @default(now())
  pagat           Boolean   @default(false)
  status          Status    @default(PENDENT)
  isActive        Boolean   @default(true)
}
