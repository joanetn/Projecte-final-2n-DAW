generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolGlobal {
  JUGADOR
  ENTRENADOR
  ADMIN_EQUIP
  ADMIN_WEB
  ARBITRE
  SUPERADMIN
}

enum RolEquip {
  JUGADOR
  ENTRENADOR
  ADMIN_EQUIP
}

enum Status {
  PENDENT // Acció pendent: jornada, partit o compra encara no processat
  COMPLETAT // Acció completada: jornada/partit jugat, compra pagada
  CANCELAT // Acció cancel·lada: jornada/partit anul·lat, compra cancel·lada
}

model Usuari {
  id            Int           @id @default(autoincrement())
  nom           String
  email         String        @unique
  contrasenya   String
  rols          UsuariRol[]
  equips        EquipUsuari[]
  notificacions Notificacio[]
  puntuacions   Puntuacio[]
  compres       Compra[]
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  isActive      Boolean       @default(true)
}

model UsuariRol {
  id       Int       @id @default(autoincrement())
  usuari   Usuari    @relation(fields: [usuariId], references: [id])
  usuariId Int
  rol      RolGlobal
  isActive Boolean   @default(true)
}

model Club {
  id       Int     @id @default(autoincrement())
  nom      String
  equips   Equip[]
  isActive Boolean @default(true)
}

model Equip {
  id               Int           @id @default(autoincrement())
  nom              String
  categoria        String
  club             Club          @relation(fields: [clubId], references: [id])
  clubId           Int
  usuaris          EquipUsuari[]
  partitsLocals    Partit[]      @relation("local_partits")
  partitsVisitants Partit[]      @relation("visitante_partits")
  lligues          Lliga[]
  isActive         Boolean       @default(true)
}

model EquipUsuari {
  id       Int      @id @default(autoincrement())
  equip    Equip    @relation(fields: [equipId], references: [id])
  equipId  Int
  usuari   Usuari   @relation(fields: [usuariId], references: [id])
  usuariId Int
  rolEquip RolEquip
  isActive Boolean  @default(true)
}

model Lliga {
  id        Int       @id @default(autoincrement())
  nom       String
  categoria String
  jornades  Jornada[]
  equips    Equip[]
  isActive  Boolean   @default(true)
}

model Jornada {
  id       Int      @id @default(autoincrement())
  nom      String
  data     DateTime
  lliga    Lliga    @relation(fields: [lligaId], references: [id])
  lligaId  Int
  partits  Partit[]
  status   Status   @default(PENDENT)
  // PENDENT: jornada no jugada
  // COMPLETAT: jornada finalitzada, tots els partits registrats
  // CANCELAT: jornada anul·lada
  isActive Boolean  @default(true)
}

model Partit {
  id          Int         @id @default(autoincrement())
  jornada     Jornada     @relation(fields: [jornadaId], references: [id])
  jornadaId   Int
  local       Equip       @relation("local_partits", fields: [localId], references: [id])
  localId     Int
  visitant    Equip       @relation("visitante_partits", fields: [visitanteId], references: [id])
  visitanteId Int
  puntuacions Puntuacio[]
  status      Status      @default(PENDENT)
  // PENDENT: partit no jugat
  // COMPLETAT: partit jugat i puntuacions registrades
  // CANCELAT: partit anul·lat
  isActive    Boolean     @default(true)
}

model Puntuacio {
  id        Int     @id @default(autoincrement())
  partit    Partit  @relation(fields: [partitId], references: [id])
  partitId  Int
  jugador   Usuari  @relation(fields: [jugadorId], references: [id])
  jugadorId Int
  punts     Int     @default(0) // punts inicials
  isActive  Boolean @default(true)
}

model Notificacio {
  id         Int      @id @default(autoincrement())
  usuari     Usuari   @relation(fields: [usuariId], references: [id])
  usuariId   Int
  titol      String
  missatge   String
  llegit     Boolean  @default(false)
  created_at DateTime @default(now()) @map("created_at")
  isActive   Boolean  @default(true)
  // Opcional: status si vols controlar "PENDENT" / "COMPLETAT" / "CANCELAT"
}

model Merch {
  id       Int      @id @default(autoincrement())
  nom      String
  marca    String
  preu     Float
  stock    Int
  compres  Compra[]
  isActive Boolean  @default(true)
}

model Compra {
  id         Int      @id @default(autoincrement())
  usuari     Usuari   @relation(fields: [usuariId], references: [id])
  usuariId   Int
  merch      Merch    @relation(fields: [merchId], references: [id])
  merchId    Int
  quantitat  Int
  total      Float
  created_at DateTime @default(now())
  pagat      Boolean  @default(false)
  status     Status   @default(PENDENT)
  // PENDENT: compra iniciada, no pagada
  // COMPLETAT: compra pagada i processada
  // CANCELAT: compra cancel·lada
  isActive   Boolean  @default(true)
}
