# Base de Datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
DATABASE_URL=postgresql://user:password@localhost:5432/tu_base_de_datos

# Entorno de la aplicación (development, production, testing)
APP_ENV=development

# Debug mode (mostrar queries SQL)
DEBUG=True

# Orígenes CORS permitidos (donde se ejecuta React)
# Separar múltiples orígenes con comas
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
